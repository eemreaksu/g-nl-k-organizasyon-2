rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper to check if user is logged in
    function isAuthenticated() {
      return request.auth != null;
    }

    // Helper to check if user has admin role in Firestore
    // WARNING: Admin privileges are verified SERVER-SIDE via JWT token claims
    // Client-side state manipulation CANNOT bypass these checks.
    function isAdmin() {
      return isAuthenticated() && 
        (
          (request.auth.token.email != null && (
            // Domain-restricted patterns — ONLY @mersin.local allowed
            request.auth.token.email.matches('^adm.*@mersin\\.local$') ||
            request.auth.token.email.matches('^deca.*@mersin\\.local$') ||
            request.auth.token.email.matches('^kptn.*@mersin\\.local$') ||
            request.auth.token.email.matches('^ldr.*@mersin\\.local$') ||
            request.auth.token.email.matches('^yonetim.*@mersin\\.local$') ||
            request.auth.token.email == 'admin@mersin.local'
          )) ||
          request.auth.token.role == 'admin' || 
          (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
           get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin')
        );
    }

    // Users collection rules
    match /users/{userId} {
      allow read: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      allow write: if isAdmin();
    }

    // Daily Data can be read by any authenticated user, but only written by admins
    match /dailyData/{document=**} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // Default rules for all other collections (config, etc.)
    match /{document=**} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }
  }
}
